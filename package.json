{
  "name": "clippull-video-downloader",
  "version": "1.3.2",
  "description": "Paste Vimeo links, download them in parallel with live progress bars.",
  "main": "main.js",
  "author": "Clip.Pull rtdeluna",
  "scripts": {
    "start": "electron .",
    "build:backend": "cd backend && python -m PyInstaller --onedir --noupx --noconfirm --name clippull-backend --distpath dist --workpath build --specpath . --version-file version_info.txt main.py",
    "build:extension": "powershell -ExecutionPolicy Bypass -File scripts/build-extension.ps1",
    "fetch:ffmpeg": "powershell -ExecutionPolicy Bypass -File scripts/fetch-ffmpeg.ps1",
    "dist": "npm run fetch:ffmpeg && npm run build:backend && npm run build:extension && electron-builder",
    "release:patch": "powershell -ExecutionPolicy Bypass -File scripts/release.ps1 -Bump patch",
    "release:minor": "powershell -ExecutionPolicy Bypass -File scripts/release.ps1 -Bump minor",
    "release:major": "powershell -ExecutionPolicy Bypass -File scripts/release.ps1 -Bump major",
    "lint:py": "ruff check backend"
  },
  "devDependencies": {
    "electron": "^33.2.0",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "appId": "com.clippull.downloader",
    "productName": "CLIP.PULL",
    "asar": true,
    "asarUnpack": [
      "backend/dist/**",
      "backend/vendor/**"
    ],
    "files": [
      "main.js",
      "preload.js",
      "package.json",
      "frontend/**/*",
      "assets/**/*",
      "backend/dist/clippull-backend/**/*",
      "backend/vendor/ffmpeg*",
      "backend/vendor/FFMPEG_LICENSE.txt"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "assets/icon.ico"
    },
    "mac": {
      "target": [
        "zip"
      ],
      "icon": "assets/icon.icns",
      "identity": null,
      "category": "public.app-category.utilities"
    },
    "directories": {
      "output": "dist"
    }
  }
}
