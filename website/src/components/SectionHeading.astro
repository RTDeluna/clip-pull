---
interface Props {
  eyebrow?: string;
  title: string;
  subtitle?: string;
  align?: "left" | "center";
  class?: string;
}
const { eyebrow, title, subtitle, align = "center", class: className = "" } = Astro.props;
const alignClass = align === "center" ? "text-center mx-auto" : "text-left";
---
<div class:list={["reveal max-w-2xl", alignClass, className]}>
  {eyebrow && (
    <p class="text-xs font-semibold uppercase tracking-[0.14em] text-accent-strong mb-3 font-mono">
      {eyebrow}
    </p>
  )}
  <h2 class="text-3xl sm:text-4xl font-extrabold tracking-tight text-text">{title}</h2>
  {subtitle && <p class="mt-4 text-base sm:text-lg text-text-dim leading-relaxed">{subtitle}</p>}
</div>
