---
import { Image } from "astro:assets";
import SectionHeading from "./SectionHeading.astro";
import queueScreenshot from "../assets/dashboard-hero.png";
import historyScreenshot from "../assets/showcase-history.png";
import settingsScreenshot from "../assets/showcase-settings.png";
import extensionScreenshot from "../assets/showcase-extension.png";
import IconBatch from "../icons/IconBatch.astro";
import IconClock from "../icons/IconClock.astro";
import IconSliders from "../icons/IconSliders.astro";
import IconPuzzle from "../icons/IconPuzzle.astro";
import IconChevronLeft from "../icons/IconChevronLeft.astro";
import IconChevronRight from "../icons/IconChevronRight.astro";
import IconExpand from "../icons/IconExpand.astro";
import IconClose from "../icons/IconClose.astro";

const tabs = [
  {
    key: "queue",
    label: "Queue",
    icon: IconBatch,
    caption: "Paste a batch of links and watch them download in parallel with live progress.",
    image: queueScreenshot,
  },
  {
    key: "history",
    label: "History",
    icon: IconClock,
    caption: "Every finished download, searchable and filterable, with one-click retry and reveal.",
    image: historyScreenshot,
  },
  {
    key: "settings",
    label: "Settings",
    icon: IconSliders,
    caption: "Tune concurrency, aria2c, duplicate handling, and your default output folder once.",
    image: settingsScreenshot,
  },
  {
    key: "extension",
    label: "Extension",
    icon: IconPuzzle,
    caption: "The companion Chrome extension, ready to install straight from the app.",
    image: extensionScreenshot,
  },
];
---
<section class="px-5 sm:px-8 py-16 sm:py-24">
  <div class="mx-auto max-w-6xl">
    <SectionHeading
      eyebrow="Take a look"
      title="Every tab, right where you'd expect it"
      subtitle="Queue, History, Settings, and the browser extension — a quick tour of the whole app."
    />

    <div class="reveal mt-14" id="showcase">
      <div class="showcase-stage relative mx-auto max-w-3xl px-9 sm:px-16">
        <button
          type="button"
          data-ripple
          data-showcase-prev
          aria-label="Previous screenshot"
          class="showcase-arrow glass-strong border border-glass-border absolute left-0 top-1/2 -translate-y-1/2 z-50"
        >
          <IconChevronLeft class="w-5 h-5" />
        </button>

        <!--
          Bento grid: every card is placed in the exact same single grid
          cell, so the grid track — not per-card sizing — is what makes
          every screenshot occupy an identical, equally-sized frame. The
          "stacked deck" look comes entirely from the --offset custom
          property each card carries (set in showcase.ts), not from any
          per-card width/height difference.
        -->
        <div class="showcase-deck grid">
          {tabs.map((tab, index) => (
            <button
              type="button"
              data-showcase-card={index}
              data-caption={tab.caption}
              aria-label={`View the ${tab.label} screenshot`}
              aria-current={index === 0 ? "true" : "false"}
              style={`--offset:${index}`}
              class="showcase-card col-start-1 row-start-1 w-full aspect-[1.91/1] rounded-panel overflow-hidden glass border border-glass-border"
            >
              <Image
                src={tab.image}
                alt={`Screenshot of the CLIP.PULL desktop app's ${tab.label} view`}
                widths={[480, 768, 1100, 1600]}
                sizes="(min-width: 1024px) 768px, 90vw"
                class="w-full h-full object-cover object-top pointer-events-none"
                loading={index === 0 ? "eager" : "lazy"}
              />
              <span class="showcase-card__zoom-hint" aria-hidden="true">
                <IconExpand class="w-5 h-5" />
                <span class="text-xs font-semibold">View full size</span>
              </span>
              <span class="showcase-card__badge glass-strong">
                <tab.icon class="w-4 h-4 text-accent" />
                {tab.label}
              </span>
            </button>
          ))}
        </div>

        <button
          type="button"
          data-ripple
          data-showcase-next
          aria-label="Next screenshot"
          class="showcase-arrow glass-strong border border-glass-border absolute right-0 top-1/2 -translate-y-1/2 z-50"
        >
          <IconChevronRight class="w-5 h-5" />
        </button>
      </div>

      <p id="showcase-caption" class="mt-6 text-center text-sm text-text-dim min-h-[1.5em]">
        {tabs[0].caption}
      </p>

      <div class="mt-5 flex items-center justify-center gap-2" role="tablist" aria-label="Screenshot pagination">
        {tabs.map((tab, index) => (
          <button
            type="button"
            data-ripple
            data-showcase-dot={index}
            role="tab"
            aria-selected={index === 0 ? "true" : "false"}
            aria-label={`Show the ${tab.label} screenshot`}
            class="showcase-dot rounded-pill"
          ></button>
        ))}
      </div>
    </div>

    <div
      id="showcase-lightbox"
      class="showcase-lightbox"
      role="dialog"
      aria-modal="true"
      aria-label="Screenshot preview"
      hidden
    >
      <button
        type="button"
        data-ripple
        data-showcase-lightbox-close
        aria-label="Close preview"
        class="showcase-lightbox__close glass-strong border border-glass-border"
      >
        <IconClose class="w-5 h-5" />
      </button>
      <img id="showcase-lightbox-img" class="showcase-lightbox__image" alt="" />
    </div>
  </div>
</section>
