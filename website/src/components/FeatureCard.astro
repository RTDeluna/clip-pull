---
import type { FeatureCategory } from "../data/features";
import IconBatch from "../icons/IconBatch.astro";
import IconBolt from "../icons/IconBolt.astro";
import IconFolder from "../icons/IconFolder.astro";
import IconClock from "../icons/IconClock.astro";
import IconSliders from "../icons/IconSliders.astro";

const registry = {
  IconBatch,
  IconBolt,
  IconFolder,
  IconClock,
  IconSliders,
};

interface Props {
  feature: FeatureCategory;
  index: number;
  class?: string;
}
const { feature, index, class: className = "" } = Astro.props;
const Icon = registry[feature.icon as keyof typeof registry];
const isSpeedCard = feature.icon === "IconBolt";
---
<div
  class:list={["reveal glass rounded-panel p-6 sm:p-7 flex flex-col gap-4", className]}
  style={`transition-delay:${index * 70}ms`}
>
  <div
    class:list={[
      "rounded-card gradient-accent grid place-items-center shrink-0",
      isSpeedCard ? "w-12 h-12" : "w-11 h-11",
    ]}
  >
    <Icon class:list={[isSpeedCard ? "w-6 h-6" : "w-5 h-5", "text-on-accent"]} />
  </div>
  <h3 class:list={["font-bold text-text", isSpeedCard ? "text-xl" : "text-lg"]}>{feature.title}</h3>
  <ul class="flex flex-col gap-2.5 text-sm text-text-dim leading-relaxed">
    {feature.bullets.map((bullet) => (
      <li class="flex gap-2.5">
        <span class="mt-2 w-1 h-1 rounded-full bg-accent-strong shrink-0"></span>
        <span>{bullet}</span>
      </li>
    ))}
  </ul>

  {isSpeedCard && (
    <div class="mt-1 h-2 rounded-pill bg-[var(--input-bg)] overflow-hidden relative">
      <div class="shimmer relative h-full w-4/5 rounded-pill gradient-accent overflow-hidden"></div>
    </div>
  )}
</div>
