---
import SectionHeading from "./SectionHeading.astro";
import FeatureCard from "./FeatureCard.astro";
import { features } from "../data/features";

// Bento layout on a 6-column base at the lg breakpoint: "Built for Speed"
// (the most content-rich card, with its own progress-bar decoration) gets
// the wide hero tile in row one alongside a narrower partner, then three
// equal tiles fill row two exactly — 2+4 / 2+2+2 = 12 of 12 cells, so
// there's never a leftover gap the way a flat 3-col grid leaves one when
// five items don't divide evenly by three. Below lg every card is span-1,
// so the grid just falls back to the existing 1-/2-column stack.
const spanByIndex = ["lg:col-span-2", "lg:col-span-4", "lg:col-span-2", "lg:col-span-2", "lg:col-span-2"];
---
<section id="features" class="px-5 sm:px-8 py-16 sm:py-24">
  <div class="mx-auto max-w-6xl">
    <SectionHeading
      eyebrow="Features"
      title="Everything you need, nothing you don't"
      subtitle="CLIP.PULL is built around one workflow: dump in a batch of links and let it work."
    />
    <div class="mt-12 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-6 gap-5">
      {features.map((feature, index) => (
        <FeatureCard feature={feature} index={index} class={spanByIndex[index] ?? ""} />
      ))}
    </div>
  </div>
</section>
