---
import SectionHeading from "./SectionHeading.astro";
import FeatureCard from "./FeatureCard.astro";
import { features } from "../data/features";
---
<section id="features" class="px-5 sm:px-8 py-16 sm:py-24">
  <div class="mx-auto max-w-6xl">
    <SectionHeading
      eyebrow="Features"
      title="Everything you need, nothing you don't"
      subtitle="CLIP.PULL is built around one workflow: dump in a batch of links and let it work."
    />
    <div class="mt-12 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {features.map((feature, index) => (
        <FeatureCard feature={feature} index={index} />
      ))}
    </div>
  </div>
</section>
